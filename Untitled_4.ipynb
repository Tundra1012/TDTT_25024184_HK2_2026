    "def what_to_wear(raining, freezing):\n",
    "    if raining:\n",
    "        if freezing:\n",
    "            return 'Waterproof coat'\n",
    "        else:\n",
    "            return 'Umbrella'\n",
    "    else:\n",
    "        if freezing:\n",
    "            return 'Warm coat'\n",
    "        else:\n",
    "            return 'Sweater'"
   ]
